# ============================================================
# ISMS Backend - Environment Variables
# ============================================================
# WARNING: Never commit this file to version control!
# Copy this to .env and fill in your actual values.

# --- Flask Core ---
SECRET_KEY=your_super_secret_flask_key_change_this_in_production
FLASK_ENV=development
DEBUG=True
PORT=5000

# --- App Seeding ---
# Default superadmin password (only used on FIRST run if no superadmin exists)
SUPERADMIN_DEFAULT_PASSWORD=admin@123!
# Format: mysql+mysqlconnector://user:password@host:port/dbname
DATABASE_URL=mysql+mysqlconnector://admin:ZLwDR01PKKvO9cd6B6iJ@isms1.c29e48ws2cbo.us-east-1.rds.amazonaws.com/isms1

# --- Database Credentials (individual, for direct use) ---
DB_HOST=isms1.c29e48ws2cbo.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_NAME=isms1
DB_USER=admin
DB_PASSWORD=ZLwDR01PKKvO9cd6B6iJ

# --- CORS ---
# Comma-separated list of allowed origins (frontend URL)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- File Storage ---
SCREENSHOT_FOLDER=storage/screenshots

# --- JWT / Token (if used) ---
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ACCESS_TOKEN_EXPIRES=3600

# --- Razorpay (Payment Gateway) ---
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
