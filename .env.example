# ============================================================
# ISMS Backend - Environment Variables EXAMPLE
# ============================================================
# Copy this file to .env and fill in your actual values.
# This file IS safe to commit - it contains no real secrets.

# --- Flask Core ---
SECRET_KEY=change_this_to_a_long_random_string
FLASK_ENV=development
DEBUG=True
PORT=5000

# --- Database (MySQL - AWS RDS) ---
DATABASE_URL=mysql+mysqlconnector://USER:PASSWORD@HOST:3306/DBNAME

# --- Database Credentials (individual) ---
DB_HOST=your-rds-host.rds.amazonaws.com
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- File Storage ---
SCREENSHOT_FOLDER=storage/screenshots

# --- JWT / Token ---
JWT_SECRET_KEY=change_this_jwt_secret
JWT_ACCESS_TOKEN_EXPIRES=3600

# --- Razorpay (Payment Gateway) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
